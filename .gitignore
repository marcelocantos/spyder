# Xcode user-specific state (checked-in .xcodeproj but not per-user prefs)
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/

# go-ios scratch state — `ios image auto` downloads the developer
# disk image into ./devimages/, and the userspace tunnel writes a
# pair-record next to the cwd. Neither is repo content.
devimages/
selfIdentity.plist
